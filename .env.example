# -- EcoSphere Environment Variables ------------------------------
# Copy this to .env and fill in your values. Never commit .env to git.

# Django
DEBUG=False
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
DJANGO_SETTINGS_MODULE=ecosphere_project.settings

# Database (PostgreSQL in production)
DB_NAME=ecosphere_db
DB_USER=ecosphere_user
DB_PASSWORD=ecosphere_pass
DB_HOST=db
DB_PORT=5432

# SQLite (dev fallback)
DATABASE_URL=sqlite:////app/db.sqlite3
